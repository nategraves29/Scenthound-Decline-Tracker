{
  "manifest_version": 3,
  "name": "Scenthound Decline Logger",
  "version": "1.0",
  "description": "Scrapes MyTime data and logs safety declines.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}
